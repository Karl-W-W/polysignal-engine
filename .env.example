# ============================================================================
# PolySignal-OS Backend — Environment Variables
# ============================================================================
# Copy to .env and fill in real values before starting.
# NEVER commit .env to git — only this .env.example template.
# ============================================================================

# --- Cloudflare Tunnel (DGX → polysignal.app ingress) ---
CLOUDFLARE_TUNNEL_TOKEN=

# --- NVIDIA / LLM ---
NVIDIA_API_KEY=                          # For NVIDIA NIM cloud supervisor (optional if using local Ollama)
USE_NVIDIA_CLOUD=false                   # Set "true" to route supervisor audit through NVIDIA Cloud NIM

# --- Ollama (Local LLM on DGX) ---
OLLAMA_HOST=http://172.17.0.1:11434     # Docker host address for Ollama
OLLAMA_MODEL=llama3.3:70b               # MasterLoop draft model
OLLAMA_CHAT_MODEL=llama3.2:3b           # Streaming agent model (lighter)
OLLAMA_SUPERVISOR_MODEL=llama3.3:70b    # Security supervisor audit model

# --- Security ---
HMAC_SECRET_KEY=                         # 256-bit hex key for HMAC signing (generate: python -c "import secrets; print(secrets.token_hex(32))")

# --- OpenClaw Sandbox ---
OPENCLAW_HOST=http://openclaw:9001      # Docker service name (or http://localhost:9001 for local dev)
OPENCLAW_API_KEY=                        # Bearer token for OpenClaw API authentication
OPENCLAW_GATEWAY_TOKEN=                  # Gateway auth token

# --- Telegram ---
TELEGRAM_BOT_TOKEN=                      # From @BotFather
TELEGRAM_CHAT_ID=                        # Comma-separated chat IDs for alerts (e.g. 1822532651)

# --- LangChain / LangSmith Tracing ---
LANGCHAIN_TRACING_V2=false              # Set "true" to enable LangSmith tracing (requires valid API key)
LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com
LANGCHAIN_API_KEY=                       # LangSmith personal API key (lsv2_pt_...)
LANGCHAIN_PROJECT=PolySignal-OS          # Production project name
LANGCHAIN_PROJECT_DEV=PolySignal-OS-dev  # Development project name

# --- Google AI (optional, legacy) ---
# GOOGLE_APPLICATION_CREDENTIALS=        # Path to service account JSON (commented out to force API key fallback)

# --- Anthropic / Claude API (for OpenClaw Gateway on DGX) ---
# Note: This is loaded via systemd drop-in on DGX, not from this .env
# ANTHROPIC_API_KEY=                     # Set in ~/.config/systemd/user/openclaw-gateway.service.d/anthropic.conf

# --- Data Paths ---
# DB_PATH=/data/polysignal.db           # SQLite database (default in Docker)
# MEMORY_PATH=/opt/loop/brain/memory.md # Memory markdown file
# SIGNAL_THRESHOLD=5.0                  # Price move threshold in percentage points (default: 5pp)
# ENV_PATH=.env                         # Path to .env file (default: .env in working dir)
